# Copy to .env.local and fill in. Also set these in the Vercel project env vars.

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Where contact inquiries and newsletter signups are delivered
CONTACT_TO_EMAIL=info@elalouealgroup.com

# Sender address — must be on a domain verified in Resend (https://resend.com/domains)
CONTACT_FROM_EMAIL=Elalou Website <website@elalouealgroup.com>
